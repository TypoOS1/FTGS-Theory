0. ЛАГРАНЖИАН ТЕОРИИ (НОВОЕ УРАВНЕНИЕ ГРАВИТАЦИИ)

L = √(-g) * [ R/(16πG) - 1/2 * (∂ϕ)² - V(ϕ) + 1/6 * ϕ * R + β * K(M|M') * ρ_info ]

ϕ(t) = 1 / √(1 + t²/t_pl²)

